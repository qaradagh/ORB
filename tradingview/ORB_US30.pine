//@version=6
// ═══════════════════════════════════════════════════════════════════════════
//  ORB US30 — استراتژی شکستِ رنجِ بازشدن (Opening Range Breakout)
//  فاز ۱: اندیکاتور تریدینگ‌ویو — قابل استفاده روی لایو (با آلرت) و بک‌تست با Bar Replay
//
//  قوانین (مطابق سند US30-ORB-Strategy-Guide-FA):
//   • رنج بازشدن = سقف و کفِ ۳ کندلِ ۵ دقیقه‌ای اول از بازشدن نقدی نیویورک (۰۹:۳۰ NY)
//   • ورود: اولین کندل ۵ دقیقه‌ای که «بیرون رنج کلوز کند» (لمس کافی نیست) — ورود روی کلوز
//   • استاپ: وسط رنج (۵۰٪) یا نسخه‌ی محافظه‌کار: طرف مقابل رنج
//   • تارگت: 3R (حالت A) — یا حالت B: نصف در 2R + استاپ به ورود + تریل پشت کف/سقف کندل قبل
//   • سقف ۲ معامله در روز؛ ری‌انتری فقط بعد از استاپ‌خوردن
//   • پنجره ورود: ۰۹:۳۰ تا ۱۱:۳۰ نیویورک (۱۵:۳۰–۱۷:۳۰ آلمان) — بعدش سیگنال وجود ندارد
//   • فیلتر ۱: رنجِ بزرگ‌تر از یک‌سومِ ATR روزانه (۱۴) ⇒ روز ممنوع
//   • فیلتر ۲: روزهای خبری (FOMC/CPI/NFP) ⇒ سوییچ دستی «روز خبری»
//   • پایان جلسه (۱۶:۰۰ NY): هر پوزیشن باز، کلوز اجباری می‌شود
//
//  نکته: همه‌ی محاسبات فقط روی «کندل بسته‌شده» انجام می‌شود ⇒ بدون ری‌پینت،
//  و نتیجه‌ی لایو، ریپلی و هیستوری یکسان است.
// ═══════════════════════════════════════════════════════════════════════════
indicator("ORB US30 — شکست رنج بازشدن", "ORB US30", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 300)

// ─────────────────────────── ورودی‌ها ───────────────────────────
grpS = "زمان‌بندی / Session"
tz        = input.string("America/New_York", "منطقه زمانی مبنا", group = grpS, tooltip = "مبنا همیشه بازشدنِ نقدی نیویورک (۰۹:۳۰) است. تغییر ساعت تابستانی خودکار اعمال می‌شود؛ لازم نیست ساعت آلمان را دستی جابه‌جا کنی.")
sessRange = input.session("0930-0945", "رنج بازشدن — ۱۵ دقیقه‌ی اول", group = grpS)
sessWin   = input.session("0930-1130", "پنجره‌ی ورود (معادل ۱۵:۳۰ تا ۱۷:۳۰ آلمان)", group = grpS)
sessDay   = input.session("0930-1600", "جلسه‌ی روز — پایانش کلوز اجباری پوزیشن است", group = grpS)

grpR = "قوانین معامله / Rules"
stopModeS   = input.string("۵۰٪ رنج (پیش‌فرض)", "محل استاپ", options = ["۵۰٪ رنج (پیش‌فرض)", "طرف مقابل رنج (محافظه‌کارتر)"], group = grpR)
targetR     = input.float(3.0, "تارگت بر حسب R", minval = 0.5, step = 0.5, group = grpR)
maxTrades   = input.int(2, "سقف معامله در روز", minval = 1, maxval = 5, group = grpR)
reAfterLoss = input.bool(true, "ری‌انتری فقط بعد از استاپ‌خوردن", group = grpR, tooltip = "طبق سند: سیگنال اول + یک ری‌انتری بعد از استاپ. اگر خاموش شود، تا سقف روزانه هر سیگنال معتبر گرفته می‌شود.")
worstCase   = input.bool(true, "استاپ و تارگت در یک کندل ⇒ باخت حساب شود", group = grpR, tooltip = "در دیتای ۵ دقیقه‌ای معلوم نیست اول کدام خورده است؛ فرض بدبینانه آمار بک‌تست را واقعی‌تر نگه می‌دارد.")

grpM = "مدیریت / Management"
mgmtModeS = input.string("A — تارگت ثابت 3R", "حالت مدیریت", options = ["A — تارگت ثابت 3R", "B — نصف در 2R + تریل تا آخر روز"], group = grpM)
trailLen  = input.int(1, "تریل پشت کف/سقفِ چند کندلِ قبل", minval = 1, maxval = 10, group = grpM)

grpF = "فیلترها / Filters"
useAtrF   = input.bool(true, "فیلتر ATR — رنجِ بزرگ‌تر از سهم ATR روزانه ⇒ روز ممنوع", group = grpF)
atrRatio  = input.float(0.333, "حداکثر رنج نسبت به ATR روزانه", minval = 0.05, maxval = 1.0, step = 0.001, group = grpF)
atrLen    = input.int(14, "طول ATR روزانه", minval = 1, group = grpF)
newsOff   = input.bool(false, "امروز روز خبری است (FOMC/CPI/NFP) — ورود جدید ممنوع", group = grpF, tooltip = "سوییچ دستی. صبحِ روزهای خبری روشنش کن و فردایش خاموش. در بک‌تست ریپلی، روزهای خبری را جداگانه یادداشت کن.")
statsFrom = input.time(timestamp("2024-01-01T00:00:00"), "شروع سیگنال و آمار از تاریخ", group = grpF, tooltip = "برای بک‌تست با ریپلی: فقط از این تاریخ به بعد معامله شبیه‌سازی و در آمار شمرده می‌شود.")

grpV = "نمایش / Display"
showBox   = input.bool(true, "کادر رنج بازشدن", group = grpV)
showBg    = input.bool(true, "هایلایت پنجره‌ی ورود", group = grpV)
showTable = input.bool(true, "جدول آمار", group = grpV)
tablePosS = input.string("بالا-راست", "محل جدول", options = ["بالا-راست", "بالا-چپ", "پایین-راست", "پایین-چپ"], group = grpV)

// رنگ‌ها
colBull  = #089981
colBear  = #f23645
colRange = #2962ff
colGray  = #787b86
colAmber = #ff9800

// ─────────────────────── سری‌های سراسری ───────────────────────
inRange = not na(time(timeframe.period, sessRange, tz))
inWin   = not na(time(timeframe.period, sessWin, tz))
inDay   = not na(time(timeframe.period, sessDay, tz))

// ATR روزانه‌ی بسته‌شده (بدون ری‌پینت)
dailyAtr = request.security(syminfo.tickerid, "D", ta.atr(atrLen)[1], lookahead = barmerge.lookahead_on)

trailLow  = ta.lowest(low, trailLen)[1]
trailHigh = ta.highest(high, trailLen)[1]

mgmtB   = str.startswith(mgmtModeS, "B")
stopMid = str.contains(stopModeS, "۵۰")

// ─────────────────────── وضعیت روز و پوزیشن ───────────────────────
var float orH = na
var float orL = na
var bool  rangeDone = false
var bool  dayOk = true
var int   tradesToday = 0
var float lastTradeR = na
var int   rangeStartIdx = na

var int   dir = 0          // 0=بدون پوزیشن  1=لانگ  -1=شورت
var float entryP = na
var float stopP = na
var float risk = na
var float tgtP = na
var float partialP = na
var bool  halfDone = false
var float bookedR = 0.0

// آمار تجمعی (برای بک‌تست با ریپلی)
var int   nT = 0
var int   nW = 0
var int   nL = 0
var float sumR = 0.0
var int   nDays = 0
var int   nSkip = 0
var int   noTradeDays = 0

// شیءهای گرافیکی روز/معامله‌ی جاری
var box  bx  = na
var line lnH = na
var line lnL = na
var line lnM = na
var line tlE = na
var line tlS = na
var line tlT = na
var line tlP = na

// خروجی‌های این کندل (برای آلرت و شکل)
bool longEntryPlot  = false
bool shortEntryPlot = false
bool exitPlot       = false
bool partialPlot    = false

f_r(float r) =>
    na(r) ? "—" : (r > 0 ? "+" : "") + str.tostring(r, "#.##") + "R"

// ─────────────────────── منطق اصلی (فقط کندل بسته‌شده) ───────────────────────
if barstate.isconfirmed
    bool newDay = inRange and not inRange[1]
    bool eodNow = not inDay and inDay[1]

    float closedR  = na
    float exitPrice = na
    string exitTxt  = na

    // ۱) کلوز اجباری پایان روز (یا پوزیشن جامانده تا روز بعد)
    if dir != 0 and (newDay or eodNow)
        float dF = dir == 1 ? 1.0 : -1.0
        closedR   := bookedR + dF * (open - entryP) / risk * (halfDone ? 0.5 : 1.0)
        exitPrice := open
        exitTxt   := "پایان روز"

    // ۲) شروع روز جدید — ریست وضعیت
    if newDay
        orH := high
        orL := low
        rangeStartIdx := bar_index
        rangeDone := false
        dayOk := true
        tradesToday := 0
        lastTradeR := na
        bx := na
        lnH := na
        lnL := na
        lnM := na
    else if inRange
        orH := math.max(nz(orH, high), high)
        orL := math.min(nz(orL, low), low)
    else if inRange[1] and not rangeDone and not na(orH)
        // ۳) رنج کامل شد — فیلتر ATR و رسم
        rangeDone := true
        float rng = orH - orL
        dayOk := not (useAtrF and not na(dailyAtr) and rng > dailyAtr * atrRatio)
        if time >= statsFrom
            nDays += 1
            if not dayOk
                nSkip += 1
        int x1 = nz(rangeStartIdx, bar_index - 3)
        if showBox
            bx := box.new(x1, orH, bar_index - 1, orL, border_color = color.new(colRange, 40), bgcolor = color.new(colRange, 88))
        lnH := line.new(bar_index - 1, orH, bar_index, orH, color = colRange, width = 2)
        lnL := line.new(bar_index - 1, orL, bar_index, orL, color = colRange, width = 2)
        lnM := line.new(bar_index - 1, (orH + orL) / 2, bar_index, (orH + orL) / 2, color = colGray, style = line.style_dashed)
        if not dayOk
            label.new(bar_index, orH, "⛔ روز ممنوع — رنج > " + str.tostring(atrRatio, "#.##") + "×ATR", style = label.style_label_down, color = color.new(colAmber, 20), textcolor = color.white, size = size.small)

    // ۴) مدیریت پوزیشن باز (استاپ / تارگت / تریل)
    if dir != 0 and na(closedR)
        float dF = dir == 1 ? 1.0 : -1.0
        if mgmtB and halfDone
            stopP := dir == 1 ? math.max(stopP, nz(trailLow, stopP)) : math.min(stopP, nz(trailHigh, stopP))
        bool hitSL  = dir == 1 ? low <= stopP : high >= stopP
        bool hitTP  = dir == 1 ? high >= tgtP : low <= tgtP
        bool hitPar = dir == 1 ? high >= partialP : low <= partialP

        if not mgmtB
            // حالت A — تارگت ثابت
            if hitSL and (not hitTP or worstCase)
                closedR := -1.0
                exitPrice := stopP
                exitTxt := "استاپ"
            else if hitTP
                closedR := targetR
                exitPrice := tgtP
                exitTxt := "تارگت"
        else
            // حالت B — نصف در 2R + تریل
            if not halfDone
                if hitSL and (not hitPar or worstCase)
                    closedR := -1.0
                    exitPrice := stopP
                    exitTxt := "استاپ"
                else if hitPar and hitSL
                    closedR := 1.0
                    exitPrice := entryP
                    exitTxt := "نصف 2R + سربه‌سر"
                else if hitPar
                    bookedR := 1.0
                    halfDone := true
                    stopP := entryP
                    partialPlot := true
            else
                if hitSL
                    closedR := bookedR + dF * (stopP - entryP) / risk * 0.5
                    exitPrice := stopP
                    exitTxt := "تریل"

    // ۵) ثبت نتیجه‌ی معامله‌ی بسته‌شده
    if not na(closedR)
        nT += 1
        sumR += closedR
        if closedR > 0.0001
            nW += 1
        else if closedR < -0.0001
            nL += 1
        lastTradeR := closedR
        exitPlot := true
        label.new(bar_index, closedR >= 0 ? high : low, (closedR >= 0 ? "✔ " : "✘ ") + exitTxt + " " + f_r(closedR), style = closedR >= 0 ? label.style_label_down : label.style_label_up, color = closedR > 0.0001 ? color.new(colBull, 15) : closedR < -0.0001 ? color.new(colBear, 15) : color.new(colGray, 15), textcolor = color.white, size = size.small)
        if not na(tlE)
            line.set_x2(tlE, bar_index)
        if not na(tlS)
            line.set_x2(tlS, bar_index)
        if not na(tlT)
            line.set_x2(tlT, bar_index)
        if not na(tlP)
            line.set_x2(tlP, bar_index)
        tlE := na
        tlS := na
        tlT := na
        tlP := na
        dir := 0
        halfDone := false
        bookedR := 0.0

    // ۶) ورود — اولین کلوز بیرون رنج، داخل پنجره
    bool allowedCount = tradesToday == 0 or (tradesToday < maxTrades and (not reAfterLoss or (not na(lastTradeR) and lastTradeR < 0)))
    bool canEnter = rangeDone and inWin and dayOk and not newsOff and dir == 0 and time >= statsFrom and allowedCount
    bool longSig  = canEnter and close > orH
    bool shortSig = canEnter and close < orL

    if longSig or shortSig
        dir := longSig ? 1 : -1
        entryP := close
        stopP := stopMid ? (orH + orL) / 2 : (longSig ? orL : orH)
        risk := math.abs(entryP - stopP)
        tgtP := entryP + (longSig ? 1 : -1) * targetR * risk
        partialP := entryP + (longSig ? 1 : -1) * 2.0 * risk
        halfDone := false
        bookedR := 0.0
        tradesToday += 1
        longEntryPlot := longSig
        shortEntryPlot := shortSig
        tlE := line.new(bar_index, entryP, bar_index, entryP, color = colGray, width = 1)
        tlS := line.new(bar_index, stopP, bar_index, stopP, color = colBear, width = 2)
        tlT := line.new(bar_index, tgtP, bar_index, tgtP, color = colBull, width = 2, style = line.style_dashed)
        if mgmtB
            tlP := line.new(bar_index, partialP, bar_index, partialP, color = colAmber, width = 1, style = line.style_dotted)

    // ۷) امتداد خطوط روز و معامله
    if not na(lnH) and inDay
        line.set_x2(lnH, bar_index)
        line.set_x2(lnL, bar_index)
        line.set_x2(lnM, bar_index)
    if dir != 0
        line.set_x2(tlE, bar_index)
        line.set_x2(tlS, bar_index)
        line.set_y1(tlS, stopP)
        line.set_y2(tlS, stopP)
        line.set_x2(tlT, bar_index)
        if not na(tlP)
            line.set_x2(tlP, bar_index)

    // ۸) روز بدون سیگنال (پنجره بسته شد و معامله‌ای نشد) — خودش یکی از خروجی‌های معتبر سیستم است
    if inWin[1] and not inWin and rangeDone and dayOk and not newsOff and tradesToday == 0 and dir == 0 and time >= statsFrom
        noTradeDays += 1
        label.new(bar_index, high, "بدون معامله", style = label.style_label_down, color = color.new(colGray, 40), textcolor = color.white, size = size.tiny)

// ─────────────────────── نمایش ───────────────────────
bgcolor(showBg and inWin ? color.new(colRange, 96) : na, title = "پنجره ورود")
plotshape(longEntryPlot, title = "ورود لانگ", style = shape.triangleup, location = location.belowbar, color = colBull, size = size.small, text = "ORB", textcolor = colBull)
plotshape(shortEntryPlot, title = "ورود شورت", style = shape.triangledown, location = location.abovebar, color = colBear, size = size.small, text = "ORB", textcolor = colBear)

// ─────────────────────── جدول آمار ───────────────────────
tPos = tablePosS == "بالا-راست" ? position.top_right : tablePosS == "بالا-چپ" ? position.top_left : tablePosS == "پایین-راست" ? position.bottom_right : position.bottom_left
var table tbl = showTable ? table.new(tPos, 2, 12, border_width = 1, border_color = color.new(colGray, 70), bgcolor = color.new(colGray, 92)) : na

if showTable and barstate.islast
    string statusTxt = dir == 1 ? "لانگ باز " + f_r(bookedR) : dir == -1 ? "شورت باز " + f_r(bookedR) : inRange ? "رنج در حال شکل‌گیری" : rangeDone and inWin ? (not dayOk ? "روز ممنوع (ATR)" : newsOff ? "روز خبری — بدون ورود" : "منتظر کلوز بیرون رنج") : "خارج از پنجره"
    float wr = nT > 0 ? nW * 100.0 / nT : na
    table.cell(tbl, 0, 0, "ORB US30", text_color = color.white, bgcolor = colRange, text_size = size.small)
    table.cell(tbl, 1, 0, mgmtB ? "حالت B" : "حالت A", text_color = color.white, bgcolor = colRange, text_size = size.small)
    if timeframe.period != "5"
        table.cell(tbl, 0, 1, "⚠ تایم‌فریم باید ۵ دقیقه باشد", text_color = color.white, bgcolor = colBear, text_size = size.small)
        table.cell(tbl, 1, 1, timeframe.period, text_color = color.white, bgcolor = colBear, text_size = size.small)
    table.cell(tbl, 0, 2, "معامله‌ها", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 2, str.tostring(nT), text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 3, "برد / باخت", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 3, str.tostring(nW) + " / " + str.tostring(nL), text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 4, "وین‌ریت", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 4, na(wr) ? "—" : str.tostring(wr, "#.#") + "٪", text_color = na(wr) ? chart.fg_color : wr >= 100.0 / (1.0 + targetR) ? colBull : colBear, text_size = size.small)
    table.cell(tbl, 0, 5, "مجموع R", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 5, f_r(sumR), text_color = sumR > 0 ? colBull : sumR < 0 ? colBear : chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 6, "میانگین R", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 6, nT > 0 ? f_r(sumR / nT) : "—", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 7, "روزهای بررسی‌شده", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 7, str.tostring(nDays), text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 8, "روز ممنوع (ATR)", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 8, str.tostring(nSkip), text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 9, "روز بدون سیگنال", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 9, str.tostring(noTradeDays), text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 10, "امروز: معامله / وضعیت", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 10, str.tostring(tradesToday) + " — " + statusTxt, text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 0, 11, "آخرین معامله", text_color = chart.fg_color, text_size = size.small)
    table.cell(tbl, 1, 11, f_r(lastTradeR), text_color = na(lastTradeR) ? chart.fg_color : lastTradeR > 0 ? colBull : lastTradeR < 0 ? colBear : chart.fg_color, text_size = size.small)

// ─────────────────────── آلرت‌ها (برای لایو) ───────────────────────
alertcondition(longEntryPlot,  "ORB — ورود لانگ",      "ORB LONG @ {{close}} — کندل ۵ دقیقه بالای سقف رنج کلوز کرد. استاپ و تارگت روی چارت.")
alertcondition(shortEntryPlot, "ORB — ورود شورت",      "ORB SHORT @ {{close}} — کندل ۵ دقیقه زیر کف رنج کلوز کرد. استاپ و تارگت روی چارت.")
alertcondition(partialPlot,    "ORB — نصف در 2R",      "ORB: قیمت به +2R رسید — نصف پوزیشن خارج، استاپ به نقطه ورود.")
alertcondition(exitPlot,       "ORB — بسته شدن معامله", "ORB: معامله بسته شد (استاپ / تارگت / تریل / پایان روز).")
